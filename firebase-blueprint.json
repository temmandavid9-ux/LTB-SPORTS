{
  "entities": {
    "users": {
      "title": "User Profile",
      "description": "Stores user profile information and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "username": { "type": "string", "description": "Display name" },
        "email": { "type": "string", "format": "email" },
        "bio": { "type": "string" },
        "profilePic": { "type": "string" },
        "favoriteTeam": { "type": "string" },
        "points": { "type": "number" },
        "level": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "username", "email"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "users",
      "description": "User profile documents"
    }
  }
}
